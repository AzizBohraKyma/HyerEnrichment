{
  "name": "hyrepath-enrichment-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "openapi:export": "python ../backend/scripts/export_openapi.py -o openapi/openapi.json",
    "openapi:gen": "openapi-typescript openapi/openapi.json -o src/lib/generated/openapi.ts",
    "openapi:check": "npm run openapi:export && npm run openapi:gen && git diff --exit-code openapi/openapi.json src/lib/generated/openapi.ts",
    "test:smoke": "cross-env FRONTEND_USE_MOCKS=true playwright test e2e/smoke.spec.ts",
    "test:e2e": "cross-env FRONTEND_USE_MOCKS=true playwright test --project=chromium",
    "test:integration": "cross-env FRONTEND_USE_MOCKS=false BACKEND_API_URL=http://localhost:8000 BACKEND_API_TOKEN=change-me playwright test e2e/integration",
    "audit:ci": "node scripts/verify-next-version.mjs && audit-ci --config audit-ci.jsonc",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.2",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "^9.3.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    },
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "audit-ci": "^7.1.0",
    "cross-env": "^7.0.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.5.3",
    "vitest": "^3.2.4"
  }
}

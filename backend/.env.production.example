# Production environment template — copy to backend/.env.production on the host.
# Staging must use the same key set; only values differ.
# Never commit real secrets.

APP_NAME="Hyrepath Enrichment Backend"
APP_ENV=production
API_TOKEN=REPLACE_WITH_PRODUCTION_TOKEN

DATABASE_URL=postgresql+asyncpg://hyrepath:REPLACE_PG_PASSWORD@postgres:5432/hyrepath
REDIS_URL=redis://redis:6379/0

R2_BUCKET=hyrepath-assets
R2_PUBLIC_BASE_URL=https://cdn.example.com
# Required when ENABLE_TIER1=true (worker fail-fast in production)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

MAX_SYNC_REQUESTS_PER_MINUTE=10
MAX_ASYNC_REQUESTS_PER_MINUTE=30
MAX_COMPLIANCE_REQUESTS_PER_MINUTE=20
AUDIT_LOG_RETENTION_YEARS=5

PROXY_MODE=none
BROWSER_MODE=multilogin
LLM_MODE=stub
EMAIL_VERIFY_LEVEL=basic
ENABLE_TIER1=false

SOCIAL_ANALYZER_URL=http://social-analyzer:9005
GMAPS_SCRAPER_URL=http://google-maps-scraper:8080
EMAIL_VERIFIER_URL=http://email-verifier:8080

GITHUB_TOKEN=
GITRECON_SCRIPT=/opt/gitrecon/gitrecon.py
GITRECON_MAX_PER_MINUTE=10
GITRECON_RATE_LIMIT_BACKOFF_SECONDS=5
GITRECON_COOLDOWN_SECONDS=60

DISAMBIGUATION_THRESHOLD=0.7

# Tier 1 worker secrets — prefer host file outside git:
#   WORKER_ENV_FILE=/etc/hyrepath/worker.env
# MULTILOGIN_EMAIL=
# MULTILOGIN_PASSWORD=
# MULTILOGIN_FOLDER_ID=
# LINKEDIN_BOT_EMAIL=
# LINKEDIN_BOT_PASSWORD=

# Observability (optional)
# SENTRY_DSN=http://public_key@glitchtip-web:8000/1
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# CHANGEDETECTION_URL=http://changedetection:5000
# NOTIFY_WEBHOOK_URL=

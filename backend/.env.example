# ─────────────────────────────────────────────
# Core (required today)
# ─────────────────────────────────────────────
# Quote values that contain spaces (required if this file is sourced or used as a Docker env_file).
APP_NAME="Hyrepath Enrichment Backend"
APP_ENV=development
API_TOKEN=change-me

# Local dev (default): single-process SQLite
DATABASE_URL=sqlite+aiosqlite:///./hyrepath.db
# Docker / production: shared Postgres so API + worker see the same jobs
# DATABASE_URL=postgresql+asyncpg://hyrepath:hyrepath@postgres:5432/hyrepath

REDIS_URL=redis://localhost:6379/0
R2_BUCKET=hyrepath-assets
R2_PUBLIC_BASE_URL=https://cdn.example.com

# TTLs + rate limits
LINKEDIN_PHOTO_TTL_SECONDS=86400
USERNAME_LOOKUP_TTL_SECONDS=3600
BUSINESS_LOOKUP_TTL_SECONDS=3600
JOB_LOOKUP_TTL_SECONDS=1800
MAX_SYNC_REQUESTS_PER_MINUTE=10
MAX_ASYNC_REQUESTS_PER_MINUTE=30

# Compliance — audit log retention (years)
AUDIT_LOG_RETENTION_YEARS=5

# ─────────────────────────────────────────────
# Provider mode switches (Phase 0)
# These 5 flags are the ONLY thing that changes free -> paid.
# Defaults = fully free / self-hosted.
# ─────────────────────────────────────────────
# none | scrapoxy | paid
PROXY_MODE=none
# local | multilogin
BROWSER_MODE=local
# stub | ollama | litellm
LLM_MODE=stub
# basic (syntax+MX) | smtp (Reacher)
EMAIL_VERIFY_LEVEL=basic
# LinkedIn off by default (hardest to do free)
ENABLE_TIER1=false

# ─────────────────────────────────────────────
# Tier 1 — LinkedIn photo (Phase 3, Multilogin + Selenium)
# Only used when ENABLE_TIER1=true on the worker (not API container).
#
# Docker: secrets are injected by docker-compose.tier1.yml via env_file
# (default ../.env, or WORKER_ENV_FILE=/path/to/worker.env in production).
# Do not put inline # comments on secret value lines — Docker env-files
# treat the comment as part of the value.
#
#   cd backend/docker
#   docker compose -f docker-compose.yml -f docker-compose.tier1.yml up -d worker
# ─────────────────────────────────────────────
# MULTILOGIN_API_URL=https://api.multilogin.com
# Host probes: leave as launcher.mlx.yt (resolves to local agent). Docker Tier 1
# maps launcher.mlx.yt -> host-gateway (or MULTILOGIN_HOST_IP on WSL2 + Docker
# Engine) in docker-compose.tier1.yml — do not change this URL just for containers.
# MULTILOGIN_LAUNCHER_URL=https://launcher.mlx.yt:45001/api/v2
# MULTILOGIN_EMAIL=
# MULTILOGIN_PASSWORD=
# MULTILOGIN_FOLDER_ID=
# MULTILOGIN_WORKSPACE_ID=
# MULTILOGIN_PROFILE_ID=
# MULTILOGIN_PROFILE_POOL_SIZE=0
# MULTILOGIN_DAILY_VIEW_LIMIT=22
# Host-native probes use 127.0.0.1; docker-compose.tier1.yml overrides to host.docker.internal
# MULTILOGIN_SELENIUM_HOST=http://127.0.0.1
# LINKEDIN_BOT_EMAIL=
# LINKEDIN_BOT_PASSWORD=
# TIER1_BROWSER_TIMEOUT_SECONDS=45
# TIER1_MAX_CONCURRENT_BROWSERS=1
# TIER1_SKIP_LOGIN_IF_SESSION_VALID=true
# TIER1_PLACEHOLDER_DENYLIST=custom-fragment,another-fragment
# MULTILOGIN_PROFILE_COOLDOWN_SECONDS=86400
# MULTILOGIN_RATE_LIMIT_COOLDOWN_SECONDS=3600
# Legacy Playwright CDP attach (optional local dev)
# MULTILOGIN_CDP_URL=http://host.docker.internal:45001
# R2 real credentials (leave unset in development -> writes to .asset-cache/)
# Required when APP_ENV=production|staging and ENABLE_TIER1=true (worker fail-fast)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────
# Tier 2 — Handle hunt (Phase 1/2, free)
# ─────────────────────────────────────────────
# social-analyzer sidecar (free, AGPL, isolated). Unset -> empty fragment.
# SOCIAL_ANALYZER_URL=http://social-analyzer:9005
SHERLOCK_TIMEOUT_SECONDS=60
MAIGRET_TIMEOUT_SECONDS=90

# ─────────────────────────────────────────────
# Tier 3 — OSINT + email (Phase 1 free, Phase 3 paid SMTP)
# ─────────────────────────────────────────────
# gitrecon / theHarvester: free GitHub token (higher rate limits, still free)
GITHUB_TOKEN=
GITRECON_SCRIPT=
THEHARVESTER_TIMEOUT_SECONDS=120
CROSSLINKED_TIMEOUT_SECONDS=90

# email-sleuth Rust binary (subprocess); falls back to local pattern gen if unset
EMAIL_SLEUTH_BIN=email-sleuth

# email-verifier (AfterShip, free) — fallback in basic mode. Unset -> skipped.
# EMAIL_VERIFIER_URL=http://email-verifier:8080

# Reacher SMTP verify (Phase 3, needs port 25 + clean IP).
# Only used when EMAIL_VERIFY_LEVEL=smtp
# REACHER_URL=http://reacher:8080
# REACHER_FROM_EMAIL=verify@yourdomain.com

# ─────────────────────────────────────────────
# Tier 4 — Jobs + business (Phase 1/2, free)
# ─────────────────────────────────────────────
JOBSPY_RESULTS_PER_BOARD=15
# google-maps-scraper sidecar (-web mode). Unset -> empty fragment.
# GMAPS_SCRAPER_URL=http://google-maps-scraper:8080
GMAPS_JOB_TIMEOUT_SECONDS=300
GMAPS_JOB_POLL_SECONDS=10

# ─────────────────────────────────────────────
# LLM disambiguation (Phase 3/4)
# Free now: LLM_MODE=stub (no keys) or ollama (local). Paid: litellm.
# ─────────────────────────────────────────────
DISAMBIGUATION_THRESHOLD=0.7
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1
# LiteLLM (paid-later) — only used when LLM_MODE=litellm
# LITELLM_API_BASE=http://litellm:4000
# LITELLM_API_KEY=
# LITELLM_MODEL=gpt-4o-mini
# LITELLM_FALLBACKS=claude-3-5-haiku,gemini-1.5-flash

# ─────────────────────────────────────────────
# Proxies (Phase 3, paid-later)
# Only used when PROXY_MODE=scrapoxy|paid
# ─────────────────────────────────────────────
# SCRAPOXY_URL=http://scrapoxy:8888
# SCRAPOXY_USERNAME=
# SCRAPOXY_PASSWORD=

# ─────────────────────────────────────────────
# Observability + signals (Phase 4, free self-host)
# ─────────────────────────────────────────────
# LANGFUSE_HOST=http://langfuse:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# CHANGEDETECTION_URL=http://changedetection:5000
# CHANGEDETECTION_API_KEY=

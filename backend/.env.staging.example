# Staging environment template — copy to backend/.env.staging on the host.
# Keys must match production; values differ (URLs, tokens, buckets).
# Never commit real secrets.

APP_NAME="Hyrepath Enrichment Backend"
APP_ENV=staging
API_TOKEN=REPLACE_WITH_STAGING_TOKEN

DATABASE_URL=postgresql+asyncpg://hyrepath:REPLACE_PG_PASSWORD@postgres:5432/hyrepath
REDIS_URL=redis://redis:6379/0

R2_BUCKET=hyrepath-assets-staging
R2_PUBLIC_BASE_URL=https://cdn-staging.example.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

MAX_SYNC_REQUESTS_PER_MINUTE=10
MAX_ASYNC_REQUESTS_PER_MINUTE=30
MAX_COMPLIANCE_REQUESTS_PER_MINUTE=20
AUDIT_LOG_RETENTION_YEARS=5

PROXY_MODE=none
BROWSER_MODE=local
LLM_MODE=stub
EMAIL_VERIFY_LEVEL=basic
ENABLE_TIER1=false

SOCIAL_ANALYZER_URL=http://social-analyzer:9005
GMAPS_SCRAPER_URL=http://google-maps-scraper:8080
EMAIL_VERIFIER_URL=http://email-verifier:8080

GITHUB_TOKEN=
GITRECON_SCRIPT=/opt/gitrecon/gitrecon.py
GITRECON_MAX_PER_MINUTE=10
GITRECON_RATE_LIMIT_BACKOFF_SECONDS=5
GITRECON_COOLDOWN_SECONDS=60

DISAMBIGUATION_THRESHOLD=0.7

# Tier 1 (worker only — use WORKER_ENV_FILE with docker-compose.tier1.yml)
# MULTILOGIN_EMAIL=
# MULTILOGIN_PASSWORD=
# MULTILOGIN_FOLDER_ID=
# LINKEDIN_BOT_EMAIL=
# LINKEDIN_BOT_PASSWORD=

# Observability (optional)
# CHANGEDETECTION_URL=http://changedetection:5000
# NOTIFY_WEBHOOK_URL=
